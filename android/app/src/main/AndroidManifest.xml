<?xml version="1.0" encoding="utf-8"?>
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        INTERNET is required for NOAA API calls (currently unused in the
        placeholder build, but needed once kayaknav's setup/build is
        wired in).
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        GLES 3.0 hint: not strictly required (wgpu picks its backend at
        runtime, typically Vulkan on modern Android), but advertising it
        keeps the app out of the Play Store "incompatible" bucket on
        very old devices without needing a manifest tweak later.
    -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <application
        android:label="KayakNav"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:hasCode="false"
        android:supportsRtl="true"
        tools:targetApi="31">

        <!--
            NativeActivity is the stock Android class that loads a .so
            and calls its `ANativeActivity_onCreate`. The
            `android.app.lib_name` meta-data names that .so without the
            `lib` prefix or `.so` suffix, matching `libname` in the
            cargo block.

            `configChanges` lets us handle rotation/keyboard without
            being re-created — eframe's event loop handles these
            internally, and an unannounced activity recreate would drop
            the egui state.
        -->
        <activity
            android:name="android.app.NativeActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|density|uiMode"
            android:launchMode="singleTask"
            android:theme="@style/Theme.KayakNav">
            <meta-data
                android:name="android.app.lib_name"
                android:value="kayaknav_android" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
